<script>
/* =====================================================================
   News list — data-driven card builder
   ---------------------------------------------------------------------
   To add a new news item: append an object to NEWS_ITEMS below with
   three fields — img, title, desc. The img path is resolved through
   Rails' asset pipeline, so save new images under
       app/assets/images/news/<your_file>.jpg
   and reference them as 'news/<your_file>.jpg'.
   ===================================================================== */
(function () {
    'use strict';

    var NEWS_ITEMS = [
        {
            img:   '<%= (asset_path("news/murari_bapu_award.jpg") rescue "") %>',
            title: 'Award From Murari Bapu',
            desc:  'The Greate award from Pu.Murari Bapu'
        }
        /* Add more items here, e.g.:
        ,{
            img:   '<%%= asset_path("news/next_event.jpg") %>',
            title: 'Next Event Title',
            desc:  'Short description of the next news item.'
        }
        */
    ];

    function escapeHTML(s) {
        return String(s == null ? '' : s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function cardHTML(item) {
        return '<li class="news-list__card">' +
                 '<div class="news-list__link">' +
                   '<div class="news-list__link-wrapper">' +
                     '<img alt="' + escapeHTML(item.title) + '" class="custom-image news-list__img" src="' + escapeHTML(item.img) + '">' +
                     '<div class="news-list__info">' +
                       '<h3 class="news-list__title">' + escapeHTML(item.title) + '</h3>' +
                       '<p class="news-list__desc">' + escapeHTML(item.desc) + '</p>' +
                     '</div>' +
                   '</div>' +
                 '</div>' +
               '</li>';
    }

    function findList() {
        return document.querySelector('ul.news-list__list') ||
               document.querySelector('[data-news-list]');
    }

    function domMatchesData(list) {
        if (!list) return false;
        var cards = list.querySelectorAll('li.news-list__card');
        if (cards.length !== NEWS_ITEMS.length) return false;
        for (var i = 0; i < NEWS_ITEMS.length; i++) {
            var titleEl = cards[i].querySelector('.news-list__title');
            var descEl  = cards[i].querySelector('.news-list__desc');
            if (!titleEl || titleEl.textContent.trim() !== NEWS_ITEMS[i].title) return false;
            if (!descEl  || descEl.textContent.trim()  !== NEWS_ITEMS[i].desc)  return false;
        }
        return true;
    }

    function renderList() {
        var list = findList();
        if (!list) return false;

        /* Only rewrite when the DOM content doesn't match our data. */
        if (domMatchesData(list)) return true;

        list.innerHTML = NEWS_ITEMS.map(cardHTML).join('');
        list.setAttribute('data-news-list', '');
        return true;
    }

    /* Aggressive enforcement window — Nuxt hydration can happen anywhere
       from ~100ms to a few seconds after the page loads, and Vue may
       rewrite the list multiple times. We re-assert our content on every
       animation frame for 6s, which is cheap (signature check short-
       circuits most calls) and robust against any hydration timing. */
    function startEnforcement() {
        var start = Date.now();
        function tick() {
            renderList();
            if (Date.now() - start < 6000) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
    }

    /* Initial render + enforcement */
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', startEnforcement);
    } else {
        startEnforcement();
    }

    /* After the enforcement window, a MutationObserver catches any late
       re-renders (e.g. route-internal navigation). */
    setTimeout(function () {
        var mo = new MutationObserver(function () {
            var list = findList();
            if (list && !domMatchesData(list)) renderList();
        });
        mo.observe(document.documentElement, { childList: true, subtree: true });
    }, 6000);
})();
</script>
<script>
(function () {
    document.addEventListener('click', function (e) {
        var link = e.target.closest('a[href]');
        if (!link) return;
        if (link.hasAttribute('download')) return;
        var href = link.getAttribute('href');
        if (!href) return;
        if (href.charAt(0) === '#' ||
            href.indexOf('://') !== -1 ||
            href.indexOf('//') === 0 ||
            href.toLowerCase().indexOf('mailto:') === 0 ||
            href.toLowerCase().indexOf('tel:') === 0) return;
        e.preventDefault();
        e.stopImmediatePropagation();
        window.location.href = href;
    }, true);
})();
</script>
<script>
  // Mirror Formspree submissions to our Rails backend (footer subscribe form on news page).
  (function () {
    var _origFetch = window.fetch;
    window.fetch = function (url, options) {
      if (typeof url === "string" && url.includes("formspree.io")) {
        try {
          var mirrorData = new FormData();
          if (options && options.body instanceof FormData) {
            options.body.forEach(function (value, key) {
              mirrorData.append(key, value);
            });
          }
          var csrfToken = (document.querySelector('meta[name="csrf-token"]') || {}).content || "";
          _origFetch("/quiz_submissions", {
            method: "POST",
            body: mirrorData,
            headers: { "X-CSRF-Token": csrfToken }
          }).catch(function (e) {
            console.warn("Rails subscribe submission failed:", e);
          });
        } catch (e) {
          console.warn("Failed to mirror subscribe submission to Rails:", e);
        }
      }
      return _origFetch.apply(this, arguments);
    };
  })();
</script>
