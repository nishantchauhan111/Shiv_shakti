                ],
                {
                    "text": 417,
                    "type": 388,
                    "marks": 418
                },
                "Investment = Management, Not a One-Time Deal",
                [
                    419
                ],
                {
                    "type": 400
                },
                {
                    "type": 383,
                    "attrs": 421
                },
                {
                    "textAlign": 12
                },
                {
                    "type": 383,
                    "attrs": 423
                },
                {
                    "textAlign": 12
                },
                {
                    "type": 383,
