        <script>
        /* ===== PROJECTS FILTER OVERRIDE =====
           Replaces Nuxt/Storyblok category system with correct filtering
           for all 11 Shiv Shakti projects.

           Animation matches the original GSAP slider:
             Backgrounds / image-items : direction-aware clip-path wipe
             Images                    : scale 1.3 → 1 zoom effect
             Text items                : translateY + opacity fade
        ===================================== */
        (function () {
            'use strict';

            /* ── Project data ─────────────────────────────────────── */
            var PROJECTS = {
                ongoing: [
                    {
                        slug: 'golden-empire',
                        title: 'The Golden Empire',
                        desc: 'Under construction luxury commercial project in prime location',
                        img: '<%= asset_path("tge.png") %>',
                        pdf: '<%= asset_path("project/The Golden Empire Brochure.pdf") %>'
                    },
                    {
                        slug: 'aawad-empire',
                        title: 'Aawad Empire',
                        desc: 'Modern residential with commercial complex with premium amenities and facilities',
                        img: '<%= asset_path("project/awad_empire.png") %>',
                        pdf: '<%= asset_path("project/Aawad Empire.pdf") %>'
                    },
                    {
                        slug: 'madhavbag',
                        title: 'Madhavbag',
                        desc: 'Premium township with world-class infrastructure and green spaces',
                        img: '<%= asset_path("project/madhavbag.png") %>',
                        pdf: '<%= asset_path("project/Madhav Bag.pdf") %>'
                    }
                ],
                completed: [
                    {
                        slug: 'alaknanda',
                        title: 'Alaknanda',
                        desc: 'A successfully completed residential project with excellent connectivity',
                        img: '<%= asset_path("project/alaknanda.png") %>',
                        pdf: '<%= asset_path("project/Alaknanda brochure.pdf") %>'
                    },
                    {
                        slug: 'luxuria-gold',
                        title: 'Luxuria Gold',
                        desc: 'Gold-standard residential development with superior finishes and design',
                        img: '<%= asset_path("project/luxuria_gold.png") %>',
                        pdf: '<%= asset_path("project/Luxuria Gold.pdf") %>'
                    },
                    {
                        slug: 'luxuria-platinum',
                        title: 'Luxuria Platinum',
                        desc: 'Platinum class residences with world-class amenities and panoramic views',
                        img: '<%= asset_path("luxuria_platinum.png") %>',
                        pdf: '<%= asset_path("project/Luxuria Platinum.pdf") %>'
                    },
                    {
                        slug: 'shiv-shakti-blessing',
                        title: 'Shiv Shakti Blessing',
                        desc: 'A blessed community offering divine living experience with modern comforts',
                        img: '<%= asset_path("project/blessing.png") %>',
                        pdf: '<%= asset_path("project/Shiv Shakti Blessing.pdf") %>'
                    },
                    {
                        slug: 'shiv-shakti-luxuria',
                        title: 'Shiv Shakti Luxuria',
                        desc: 'Luxurious residences with elegant design and premium lifestyle amenities',
                        img: '<%= asset_path("shiv_shakti_luxuria.png") %>',
                        pdf: '<%= asset_path("project/SHIV SHAKTI LUXURIA.pdf") %>'
                    },
                    {
                        slug: 'luxuria-crystal',
                        title: 'Luxuria Crystal',
                        desc: 'Crystal standard of premium living with transparent quality and craftsmanship',
                        img: '<%= asset_path("luxuria_crystel.png") %>',
                        pdf: '<%= asset_path("project/Luxuria Crystal.pdf") %>'
                    }
                ],
                upcoming: [
                    {
                        slug: 'golden-plaza',
                        title: 'Golden Plaza',
                        desc: 'An upcoming landmark commercial and residential development in prime location',
                        img: '<%= asset_path("project/golden_plaza.png") %>',
                        pdf: '<%= asset_path("project/Golden Plaza.pdf") %>'
                    },
                    {
                        slug: 'the-empire',
                        title: 'The Empire',
                        desc: 'Future landmark development setting new benchmarks in luxury',
                        img: '<%= asset_path("the_empire_kalanala.png") %>',
                        pdf: '<%= asset_path("project/The Empire.pdf") %>'
                    }
                ]
            };

            /* ── State ─────────────────────────────────────────────── */
            var currentCategory = 'ongoing';
            var currentIndex    = 0;
            var isAnimating     = false;

            /* Animation constants matching original GSAP timeline */
            var DUR  = 1.3;   /* seconds — matches GSAP defaults.duration */
            var EASE = 'cubic-bezier(0.25, 1, 0.5, 1)'; /* ≈ power1.out */

            var CLIP_VISIBLE     = 'inset(0 0% 0 0%)';
            var CLIP_HIDE_RIGHT  = 'inset(0 0 0 100%)'; /* slide out to right / enter from right */
            var CLIP_HIDE_LEFT   = 'inset(0 100% 0 0)'; /* slide out to left  / enter from left  */

            function getProjects(cat) {
                return PROJECTS[cat] || PROJECTS.ongoing;
            }

            /* ── Build HTML matching original SSR structure exactly ── */
            function bgHTML(p, i) {
                /* Background wrappers are position:absolute via CSS.
                   data-f-bg-i on the img is needed for the scale animation selector. */
                return '<div data-f-bg' +
                    ' class="' + (i === 0 ? 'active ' : '') + 'projects__bg-wrapper"' +
                    ' data-v-00c1618f>' +
                    '<img onerror="this.setAttribute(\'data-error\',1)" width="1920" alt' +
                    ' data-nuxt-img class="custom-image projects__bg" data-f-bg-i' +
                    ' data-v-00c1618f src="' + p.img + '" data-v-565e5924>' +
                    '</div>';
            }

            function imgHTML(p, i) {
                /* First item is position:relative (sets slider height), rest absolute. */
                return '<div data-f-img' +
                    ' class="' + (i === 0 ? 'active ' : '') + 'projects__image-item"' +
                    ' style="position:' + (i === 0 ? 'relative' : 'absolute') + ';"' +
                    ' data-v-00c1618f>' +
                    '<div class="projects__img-wrapper" data-f-img-i data-v-00c1618f>' +
                    '<img onerror="this.setAttribute(\'data-error\',1)" width="1920" alt' +
                    ' data-nuxt-img class="custom-image projects__img" data-t-img' +
                    ' data-slug="' + p.slug + '" data-v-00c1618f src="' + p.img + '"' +
                    ' data-v-565e5924>' +
                    '</div></div>';
            }

            function textHTML(p, i) {
                /* All text items are position:absolute stacked — CSS rule forces this.
                   We control visibility via opacity + translateY. */
                return '<div class="projects__text"' +
                    ' style="position:' + (i === 0 ? 'relative' : 'absolute') + ';"' +
                    ' data-v-00c1618f>' +
                    '<h2 data-f-title class="projects__title" data-v-00c1618f>' +
                    p.title + '</h2>' +
                    '<p data-f-text class="projects__desc" data-v-00c1618f>' +
                    p.desc + '</p>' +
                    '</div>';
            }

            /* ── Mobile list (separate Vue component, separate DOM tree) ──
               Below 860px Vue mounts ProjectsListMobile (data-v-03285327)
               which renders <section class="projects-m"> with a vertical
               <ul class="projects-m__list"> of project cards. The SSR
               doesn't include this section — it appears only after Vue
               hydrates. The desktop structure (.projects__bgs etc.) does
               not exist on mobile, so the desktop-targeted rebuild is a
               no-op there. We need a mobile-specific builder. */
            function escapeAttr(s) {
                return String(s == null ? '' : s)
                    .replace(/&/g, '&amp;')
                    .replace(/"/g, '&quot;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;');
            }

            function mobileItemHTML(p) {
                /* Vue's mobile component scope: data-v-03285327.
                   Adding it on every element keeps the scoped CSS working. */
                var dv = ' data-v-03285327=""';
                var hasPdf = !!p.pdf;
                var href = hasPdf ? p.pdf : ('/projects/' + p.slug);
                var label = hasPdf ? 'Download Brochure' : 'Go to Project';
                var dl = hasPdf ? ' download target="_blank" rel="noopener"' : '';
                return '<li class="projects-m__item project-m"' + dv + '>' +
                    '<div class="project-m__bg"' + dv + '>' +
                        '<img class="custom-image project-m__bg" src="' + escapeAttr(p.img) +
                        '" alt="' + escapeAttr(p.title) + '" width="800"' + dv + ' data-v-565e5924>' +
                    '</div>' +
                    '<div class="project-m__card" data-t-card data-slug="' + escapeAttr(p.slug) + '"' + dv + '>' +
                        '<div class="project-m__img-wrapper" data-f-img-i' + dv + '>' +
                            '<img class="custom-image project-m__card-img" data-t-img' +
                            ' src="' + escapeAttr(p.img) + '" data-slug="' + escapeAttr(p.slug) +
                            '" alt="' + escapeAttr(p.title) + '" width="800"' + dv + ' data-v-565e5924>' +
                        '</div>' +
                        '<div class="project-m__content"' + dv + '>' +
                            '<h2 class="project-m__title"' + dv + '>' + escapeAttr(p.title) + '</h2>' +
                            '<p class="project-m__text"' + dv + '>' + escapeAttr(p.desc) + '</p>' +
                            '<a class="m-project__link btn btn--primary" href="' + escapeAttr(href) + '"' +
                            dl + dv + ' data-v-7d38ae27>' +
                                '<span class="btn__content-wrapper" data-v-7d38ae27>' +
                                    '<span class="btn__content" data-v-7d38ae27>' +
                                        '<span' + dv + '>' + label + '</span>' +
                                        '<svg width="20" height="20" viewbox="0 0 20 20" fill="none"' +
                                        ' xmlns="http://www.w3.org/2000/svg"' + dv + '>' +
                                        '<path d="M3.53102 3.52659L15.3258 3.51869L15.3272 3.51732L15.3285 3.51869L16.5067 3.51791L16.4981 16.4913L14.8304 16.4924L14.8371 6.36442L4.13151 17.07L2.953 15.8915L13.6568 5.18766L3.52992 5.19436L3.53102 3.52659Z"' +
                                        ' fill="currentColor"></path></svg>' +
                                    '</span>' +
                                '</span>' +
                            '</a>' +
                        '</div>' +
                    '</div>' +
                '</li>';
            }

            function rebuildMobileList(projects) {
                var listEl = document.querySelector('.projects-m__list');
                if (!listEl) return false;
                listEl.innerHTML = projects.map(mobileItemHTML).join('');
                /* Hide the "More" button if it exists — we have ≤10 projects per
                   category so all fit in the initial slice and "More" is unwanted. */
                var moreBtn = document.querySelector('.projects-m__more-btn');
                if (moreBtn) moreBtn.style.display = 'none';
                return true;
            }

            function mobileTitlesMatch() {
                var titles = document.querySelectorAll('.projects-m__list .project-m__title');
                if (titles.length === 0) return true;
                var projects = getProjects(currentCategory);
                if (titles.length !== projects.length) return false;
                var expected = {};
                for (var i = 0; i < projects.length; i++) {
                    expected[projects[i].title.trim()] = true;
                }
                for (var j = 0; j < titles.length; j++) {
                    if (!expected[titles[j].textContent.trim()]) return false;
                }
                return true;
            }

            /* ── Set a CSS property immediately (no transition) ─────── */
            function setNow(el, prop, val) {
                if (!el) return;
                el.style[prop] = val;
            }

            /* ── Force layout flush so transition picks up from state ─ */
            function flush() {
                document.querySelector('.projects__bgs').getBoundingClientRect();
            }

            /* ── Apply transition string ────────────────────────────── */
            function transition(el, props, dur, delay) {
                if (!el) return;
                var t = props.map(function (p) {
                    return p + ' ' + dur + 's ' + (delay ? delay + 's ' : '') + EASE;
                }).join(', ');
                el.style.transition = t;
            }

            /* ── Initialize states immediately after rebuild (no anim) */
            function initSliderStates() {
                var bgs      = [].slice.call(document.querySelectorAll('.projects__bgs [data-f-bg]'));
                var bgImgs   = [].slice.call(document.querySelectorAll('.projects__bgs [data-f-bg-i]'));
                var imgs     = [].slice.call(document.querySelectorAll('[data-t-assets] [data-f-img]'));
                var imgInner = [].slice.call(document.querySelectorAll('[data-t-assets] [data-f-img-i]'));
                var texts    = [].slice.call(document.querySelectorAll('.projects__text-wrapper .projects__text'));

                bgs.forEach(function (el, i) {
                    el.style.transition = 'none';
                    el.style.clipPath   = i === 0 ? CLIP_VISIBLE : CLIP_HIDE_RIGHT;
                });
                bgImgs.forEach(function (el, i) {
                    el.style.transition = 'none';
                    el.style.transform  = i === 0 ? 'scale(1)' : 'scale(1.3)';
                });
                imgs.forEach(function (el, i) {
                    el.style.transition = 'none';
                    el.style.clipPath   = i === 0 ? CLIP_VISIBLE : CLIP_HIDE_RIGHT;
                });
                imgInner.forEach(function (el, i) {
                    el.style.transition = 'none';
                    el.style.transform  = i === 0 ? 'scale(1)' : 'scale(1.3)';
                });
                texts.forEach(function (el, i) {
                    el.style.transition = 'none';
                    el.style.opacity    = i === 0 ? '1' : '0';
                    el.style.transform  = i === 0 ? 'translateY(0)' : 'translateY(20px)';
                });
            }

            /* ── Update card link/label based on project (PDF vs. page) ── */
            function updateCardLink(link, card, project) {
                if (!project) return;
                if (card) card.setAttribute('data-slug', project.slug);
                if (!link) return;
                var labels = link.querySelectorAll('.btn__content span[data-v-00c1618f]');
                if (project.pdf) {
                    link.href = project.pdf;
                    link.setAttribute('download', '');
                    link.setAttribute('rel', 'noopener');
                    link.setAttribute('target', '_blank');
                    for (var i = 0; i < labels.length; i++) labels[i].textContent = 'Download Brochure';
                } else {
                    link.href = '/projects/' + project.slug;
                    link.removeAttribute('download');
                    link.removeAttribute('target');
                    for (var j = 0; j < labels.length; j++) labels[j].textContent = 'Go to Project';
                }
            }

            /* ── Rebuild entire slider for a project list ──────────── */
            function rebuildSlider(projects) {
                var bgsEl    = document.querySelector('.projects__bgs');
                var assetsEl = document.querySelector('[data-t-assets]');
                var textEl   = document.querySelector('.projects__text-wrapper');
                var card     = document.querySelector('.projects__card');
                var link     = document.querySelector('.projects__link');

                if (!bgsEl || !assetsEl || !textEl) return false;

                bgsEl.innerHTML    = '<!--[-->' + projects.map(bgHTML).join('') + '<!--]-->';
                assetsEl.innerHTML = '<!--[-->' + projects.map(imgHTML).join('') + '<!--]-->';
                textEl.innerHTML   = '<!--[-->' + projects.map(textHTML).join('') + '<!--]-->';

                /* Update card slug and link (PDF download or project page) */
                updateCardLink(link, card, projects[0]);

                /* Set initial visual states (no animation) */
                initSliderStates();
                return true;
            }

            /* ── Navigate to prev / next slide ────────────────────── */
            function navigate(dir) {
                if (isAnimating) return;

                var projects = getProjects(currentCategory);
                if (projects.length < 2) return;

                isAnimating = true;

                var prevIndex = currentIndex;
                currentIndex  = (currentIndex + dir + projects.length) % projects.length;

                var bgs      = [].slice.call(document.querySelectorAll('.projects__bgs [data-f-bg]'));
                var bgImgs   = [].slice.call(document.querySelectorAll('.projects__bgs [data-f-bg-i]'));
                var imgs     = [].slice.call(document.querySelectorAll('[data-t-assets] [data-f-img]'));
                var imgInner = [].slice.call(document.querySelectorAll('[data-t-assets] [data-f-img-i]'));
                var texts    = [].slice.call(document.querySelectorAll('.projects__text-wrapper .projects__text'));
                var card     = document.querySelector('.projects__card');
                var link     = document.querySelector('.projects__link');

                var goingRight  = dir === 1;

                /* Clip values:
                   entering slide starts hidden on the side we're coming FROM,
                   leaving slide exits to the opposite side.
                   goingRight → new enters from right (HIDE_RIGHT), old exits to left (HIDE_LEFT) */
                var clipEnter = goingRight ? CLIP_HIDE_RIGHT : CLIP_HIDE_LEFT;
                var clipExit  = goingRight ? CLIP_HIDE_LEFT  : CLIP_HIDE_RIGHT;

                var cur = {
                    bg:      bgs[currentIndex],
                    bgImg:   bgImgs[currentIndex],
                    img:     imgs[currentIndex],
                    inner:   imgInner[currentIndex],
                    text:    texts[currentIndex]
                };
                var prev = {
                    bg:      bgs[prevIndex],
                    bgImg:   bgImgs[prevIndex],
                    img:     imgs[prevIndex],
                    inner:   imgInner[prevIndex],
                    text:    texts[prevIndex]
                };

                /* ─ Step 1: Set entering slide to hidden start state (no transition) */
                if (cur.bg)    { cur.bg.style.transition = 'none';    cur.bg.style.clipPath  = clipEnter; }
                if (cur.img)   { cur.img.style.transition = 'none';   cur.img.style.clipPath = clipEnter; }
                if (cur.bgImg) { cur.bgImg.style.transition = 'none'; cur.bgImg.style.transform = 'scale(1.3)'; }
                if (cur.inner) { cur.inner.style.transition = 'none'; cur.inner.style.transform = 'scale(1.3)'; }
                if (cur.text)  {
                    cur.text.style.transition = 'none';
                    cur.text.style.opacity    = '0';
                    cur.text.style.transform  = goingRight ? 'translateY(25px)' : 'translateY(-25px)';
                }

                /* ─ Step 2: Force reflow so browser acknowledges the starting state */
                flush();

                /* ─ Step 3: Apply transitions and animate to final states */
                var clipDur = DUR + 's ' + EASE;
                var scaleDur = DUR + 's ' + EASE;

                /* Exiting slide wipes out */
                if (prev.bg)  {
                    prev.bg.style.transition = 'clip-path ' + clipDur;
                    prev.bg.style.clipPath   = clipExit;
                }
                if (prev.img) {
                    prev.img.style.transition = 'clip-path ' + clipDur;
                    prev.img.style.clipPath   = clipExit;
                }
                /* Exiting images zoom out slightly as they leave */
                if (prev.bgImg) {
                    prev.bgImg.style.transition = 'transform ' + scaleDur;
                    prev.bgImg.style.transform  = 'scale(1.3)';
                }
                if (prev.inner) {
                    prev.inner.style.transition = 'transform ' + scaleDur;
                    prev.inner.style.transform  = 'scale(1.3)';
                }
                /* Exiting text fades out quickly */
                if (prev.text) {
                    prev.text.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
                    prev.text.style.opacity    = '0';
                    prev.text.style.transform  = goingRight ? 'translateY(-15px)' : 'translateY(15px)';
                }

                /* Entering slide wipes in */
                if (cur.bg) {
                    cur.bg.style.transition = 'clip-path ' + clipDur;
                    cur.bg.style.clipPath   = CLIP_VISIBLE;
                }
                if (cur.img) {
                    cur.img.style.transition = 'clip-path ' + clipDur;
                    cur.img.style.clipPath   = CLIP_VISIBLE;
                }
                /* Entering images zoom in to natural size */
                if (cur.bgImg) {
                    cur.bgImg.style.transition = 'transform ' + scaleDur;
                    cur.bgImg.style.transform  = 'scale(1)';
                }
                if (cur.inner) {
                    cur.inner.style.transition = 'transform ' + scaleDur;
                    cur.inner.style.transform  = 'scale(1)';
                }

                /* Entering text fades in after image is partway through */
                var curTextEl = cur.text;
                var curGoingRight = goingRight;
                setTimeout(function () {
                    if (curTextEl) {
                        curTextEl.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
                        curTextEl.style.opacity    = '1';
                        curTextEl.style.transform  = 'translateY(0)';
                    }
                }, 400);

                /* Update active / prev classes */
                bgs.forEach(function (el, i) {
                    el.classList.toggle('active', i === currentIndex);
                    el.classList.toggle('prev',   i === prevIndex && i !== currentIndex);
                });
                imgs.forEach(function (el, i) {
                    el.classList.toggle('active', i === currentIndex);
                    el.classList.toggle('prev',   i === prevIndex && i !== currentIndex);
                });

                /* Update card slug and link (PDF download or project page) */
                updateCardLink(link, card, projects[currentIndex]);

                /* Unlock after animation completes */
                setTimeout(function () { isAnimating = false; }, DUR * 1000 + 100);
            }

            /* ── Wire navigation arrows ────────────────────────────── */
            function setupNav() {
                var navBtns = document.querySelectorAll('.floating-nav__btn');
                if (navBtns.length >= 2) {
                    /* Clone to remove any previous listeners */
                    [0, 1].forEach(function (idx) {
                        var old = navBtns[idx];
                        var fresh = old.cloneNode(true);
                        old.parentNode.replaceChild(fresh, old);
                    });

                    var btns = document.querySelectorAll('.floating-nav__btn');
                    btns[0].addEventListener('click', function (e) {
                        e.stopImmediatePropagation();
                        navigate(-1);
                    }, true);
                    btns[1].addEventListener('click', function (e) {
                        e.stopImmediatePropagation();
                        navigate(1);
                    }, true);
                }
            }

            /* ── Replace Nuxt's dynamic filter buttons ─────────────── */
            function rebuildFilterButtons() {
                var filterUl = document.querySelector('.category-filter');
                if (!filterUl) return;

                var categories = [
                    { key: 'ongoing',   label: 'ONGOING'   },
                    { key: 'completed', label: 'COMPLETED' },
                    { key: 'upcoming',  label: 'UPCOMING'  }
                ];

                filterUl.innerHTML = categories.map(function (cat, i) {
                    var isActive = cat.key === currentCategory;
                    var sep = i < categories.length - 1
                        ? '<span role="separator" aria-orientation="vertical" data-v-688578a0>|</span>'
                        : '';
                    return '<li class="category-filter__item' +
                        (isActive ? ' category-filter__item--active' : '') +
                        '" data-v-688578a0>' +
                        '<button type="button" class="category-filter__btn underline' +
                        (isActive ? ' underline--active' : '') +
                        '" data-custom-filter="' + cat.key + '" data-v-688578a0>' +
                        cat.label + '</button>' + sep + '</li>';
                }).join('');

                /* Delegated click — capture phase beats Nuxt.
                   Match either our data-custom-filter (set above) OR Nuxt's
                   data-filter (the SSR/hydrated form) — on slow mobile, Nuxt
                   may re-render the list after our init runs, restoring its
                   own data-filter attributes; with both supported, the
                   handler keeps working through that race. */
                filterUl.addEventListener('click', function (e) {
                    var btn = e.target.closest('[data-custom-filter], [data-filter]');
                    if (!btn) return;
                    e.stopImmediatePropagation();

                    var cat = btn.getAttribute('data-custom-filter') ||
                              btn.getAttribute('data-filter');
                    if (!cat || cat === currentCategory) return;   /* no-op if same category */

                    currentCategory = cat;
                    currentIndex    = 0;

                    /* Update active styling on buttons */
                    filterUl.querySelectorAll('.category-filter__item').forEach(function (li) {
                        li.classList.remove('category-filter__item--active');
                    });
                    filterUl.querySelectorAll('.category-filter__btn').forEach(function (b) {
                        b.classList.remove('underline--active');
                    });
                    var li = btn.closest('.category-filter__item');
                    if (li) li.classList.add('category-filter__item--active');
                    btn.classList.add('underline--active');

                    rebuildSlider(getProjects(cat));
                    setupNav();
                }, true);
            }

            /* ── Boot ──────────────────────────────────────────────── */
            function init() {
                var filterUl = document.querySelector('.category-filter');
                if (!filterUl) {
                    setTimeout(init, 300);
                    return;
                }

                rebuildFilterButtons();

                /* Desktop slider: only update if its DOM is present. */
                var bgsEl = document.querySelector('.projects__bgs');
                if (bgsEl) {
                    rebuildSlider(getProjects(currentCategory));
                    setupNav();
                }

                /* Mobile list: only update if its DOM is present (Vue mounts
                   ProjectsListMobile under 860px after hydration). */
                rebuildMobileList(getProjects(currentCategory));
            }

            /* Give Nuxt ~700 ms to hydrate, then take over */
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function () { setTimeout(init, 700); });
            } else {
                setTimeout(init, 700);
            }

            /* ── Mobile-specific safety nets ─────────────────────────────
               Two ADDITIONS only (no changes to anything above). They
               cannot break desktop because:
                 • The doc-level click handler runs in capture and only
                   takes over when a filter button is clicked. On desktop
                   it just runs the same logic before the existing UL-level
                   handler (stopImmediatePropagation prevents the duplicate).
                 • The MutationObserver observes ONLY childList on the
                   text-wrapper (and its parent) — NOT attributes. The
                   slide-transition animation only changes style/class
                   attributes, so the observer never fires during a slide.
                 • Both rebuild paths skip when isAnimating is true. */

            /* (1) Document-level filter click delegation. Critical detail:
               the compiled Vue CategoryFilter component renders buttons
               WITHOUT any data-filter/data-custom-filter attributes (just
               class + Vue @click). So when Nuxt hydrates on mobile and
               replaces the SSR buttons with Vue-rendered attribute-less
               buttons, an attribute-based selector finds nothing. We
               instead match by class (.category-filter__btn) and infer
               the category from the button's text content — that survives
               every render path (SSR, our rebuild, Nuxt's hydration). */
            var TEXT_TO_CATEGORY = {
                'ONGOING':   'ongoing',
                'COMPLETED': 'completed',
                'UPCOMING':  'upcoming'
            };

            document.addEventListener('click', function (e) {
                if (!e.target || !e.target.closest) return;
                var btn = e.target.closest('.category-filter__btn');
                if (!btn) return;
                var ul = btn.closest('.category-filter');
                if (!ul) return;

                /* Resolve category in this priority:
                     1. our data-custom-filter (if our rebuild is still in DOM)
                     2. SSR's data-filter (if SSR buttons are still in DOM)
                     3. button text mapped to a known category (Vue-rendered case) */
                var cat = btn.getAttribute('data-custom-filter') ||
                          btn.getAttribute('data-filter') ||
                          TEXT_TO_CATEGORY[btn.textContent.replace(/\s+/g, ' ').trim().toUpperCase()];
                if (!cat || cat === currentCategory) return;

                /* Block Vue's @click handler from running — otherwise Vue
                   would emit its own 'filter' event, the parent would
                   re-render the slider from stale __NUXT_DATA__, and
                   we'd be back to the start. */
                e.preventDefault();
                e.stopImmediatePropagation();

                currentCategory = cat;
                currentIndex    = 0;

                ul.querySelectorAll('.category-filter__item').forEach(function (li) {
                    li.classList.remove('category-filter__item--active');
                });
                ul.querySelectorAll('.category-filter__btn').forEach(function (b) {
                    b.classList.remove('underline--active');
                });
                var liEl = btn.closest('.category-filter__item');
                if (liEl) liEl.classList.add('category-filter__item--active');
                btn.classList.add('underline--active');

                /* Update both renderings — whichever DOM exists for the
                   current viewport will be updated, the other is a no-op. */
                rebuildSlider(getProjects(cat));
                setupNav();
                rebuildMobileList(getProjects(cat));
            }, true /* capture phase, so we beat any Nuxt bubble handler */);

            /* (2) Hydration watch — rebuilds slider OR mobile list when
               Nuxt overwrites with stale __NUXT_DATA__. Observes only
               childList (not attributes) so slide-transition animations
               don't trigger it. Reconcile is rAF-debounced and skips
               while isAnimating. */
            (function setupHydrationWatch() {
                function start() {
                    var anchor = document.querySelector('main') || document.body;
                    if (!anchor) { setTimeout(start, 300); return; }

                    var pending = false;

                    function desktopTitlesMatch() {
                        var titles = document.querySelectorAll('.projects__text-wrapper .projects__title');
                        if (titles.length === 0) return true;
                        var projects = getProjects(currentCategory);
                        if (titles.length !== projects.length) return false;
                        var expected = {};
                        for (var i = 0; i < projects.length; i++) {
                            expected[projects[i].title.trim()] = true;
                        }
                        for (var j = 0; j < titles.length; j++) {
                            if (!expected[titles[j].textContent.trim()]) return false;
                        }
                        return true;
                    }

                    function reconcile() {
                        pending = false;
                        if (isAnimating) return;

                        /* Desktop slider reconcile (only if its DOM is present). */
                        if (document.querySelector('.projects__text-wrapper') && !desktopTitlesMatch()) {
                            rebuildSlider(getProjects(currentCategory));
                            setupNav();
                        }

                        /* Mobile list reconcile (only if its DOM is present). */
                        if (document.querySelector('.projects-m__list') && !mobileTitlesMatch()) {
                            rebuildMobileList(getProjects(currentCategory));
                        }
                    }

                    var mo = new MutationObserver(function () {
                        if (pending) return;
                        pending = true;
                        requestAnimationFrame(reconcile);
                    });
                    /* Observe the page body so we catch BOTH the desktop slider's
                       hydration AND the moment Vue mounts the mobile list (which
                       is a fresh element added to the DOM). childList only — no
                       attribute observation, so animations don't trigger this. */
                    mo.observe(anchor, { childList: true, subtree: true });
                }
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', start);
                } else {
                    start();
                }
            })();
        })();
        </script>

