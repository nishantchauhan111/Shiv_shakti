        <script>
          (function(){
            var LOGO='/assets/building_logo-06bfecb9.png';
            function fix(){
              var all=document.querySelectorAll('link[rel*="icon"]');
              var found=false;
              for(var i=0;i<all.length;i++){
                if(all[i].href.indexOf('building_logo')!==-1){found=true;}
                else{all[i].parentNode.removeChild(all[i]);}
              }
              if(!found){var l=document.createElement('link');l.rel='icon';l.type='image/png';l.href=LOGO;document.head.appendChild(l);}
            }
            fix();
            new MutationObserver(function(ms){
              ms.forEach(function(m){
                m.addedNodes.forEach(function(n){
                  if(n.tagName==='LINK'&&n.rel&&n.rel.indexOf('icon')!==-1&&n.href.indexOf('building_logo')===-1){
                    n.href=LOGO;n.type='image/png';
                  }
                });
              });
            }).observe(document.documentElement,{subtree:true,childList:true,attributes:true,attributeFilter:['href']});
          })();
        </script>
